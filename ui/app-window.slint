export global MainState {
    in-out property <string> time;
    in-out property <string> date;
    in-out property <int> vol;
    in-out property <int> mic;
    in property <int> brightness;
    in property <percent> cpu;
    in property <percent> disk;
    pure callback get-time();
    pure callback get-date();
    pure callback get-volume();
    pure callback set-volume(int);
    pure callback get-mic();
    pure callback set-mic(int);
    pure callback get-bright();
    pure callback set-bright(int);
    pure callback get-disk();
    pure callback get-cpu();
    pure public function is-light-theme() -> bool {
        if Palette.color-scheme == ColorScheme.light {
            return true;
        } else {
            return false;
        }
    }
}

export component Menu inherits Window {
    out property <bool> first-run: true;
    property <int> volume <=> MainState.vol;
    property <int> mic <=> MainState.mic;
    property <int> bright <=> MainState.brightness;
    property <percent> cpu <=> MainState.cpu;
    property <percent> disk <=> MainState.disk;
    callback power-action(string);

    changed cpu => {
        cpu-bar.progress = self.cpu;
    }

    changed disk => {
        disk-bar.progress = self.disk;
    }
    changed mic => {
        mic-slider.value = self.mic;
    }
    changed volume => {
        vol-slider.value = self.volume;
    }
    changed bright => {
        bright-slider.value = self.bright;
    }
    width: 376px;
    height: 576px;
    background: transparent;
    public function set_dark_theme() {
        Palette.color-scheme = ColorScheme.dark;
    }
    public function set_light_theme() {
        Palette.color-scheme = ColorScheme.light;
    }

    Timer {
        running: true;
        interval: 1s;
        triggered => {
            MainState.get-time();
            MainState.get-volume();
            MainState.get-mic();
            MainState.get-bright();
            MainState.get-cpu();
            if first-run {
                first-run = false;
                MainState.get-date();
                MainState.get-disk();
            }
        }
    }

    Timer {
        running: true;
        interval: 3600s;
        triggered => {
            MainState.get-date();
            MainState.get-disk();
        }
    }

    Rectangle {
        clip: true;
        border-radius: UAppTheme.radius-medium;

        menu := Rectangle {
            width: parent.width - 50px;
            height: parent.height;
            background: UAppTheme.bg-container;
            x: 50px;
            y: 0px;
            VerticalLayout {
                padding: UAppTheme.padding-medium;
                spacing: UAppTheme.spacing-big;
                VerticalLayout {
                    UTitle {
                        text: "Hi Ramayen !";
                        vertical-alignment: TextVerticalAlignment.top;
                        height: 55px;
                    }

                    UDivider {
                        width: parent.width - 2 * UAppTheme.padding-medium;
                        height: 7px;
                        border-color: UAppTheme.bg-spotlight;
                    }
                }

                Rectangle {
                    height: 80px;
                    HorizontalLayout {
                        alignment: stretch;
                        padding: UAppTheme.padding-medium;
                        VerticalLayout {
                            spacing: UAppTheme.spacing-base;
                            alignment: start;
                            UText {
                                text: MainState.time;
                                font-size: UAppTheme.font-size-bigger;
                            }

                            UText {
                                text: MainState.date;
                                font-size: UAppTheme.font-size-bigger;
                            }
                        }

                        UButton {
                            width: 40px;
                            icon: @image-url("../assets/sleek/outlined/caret-right.svg");
                            icon-placement: start;
                        }
                    }
                }

                UCard {
                    height: 90px;
                    HorizontalLayout {
                        padding: UAppTheme.padding-medium;
                        spacing: UAppTheme.spacing-medium;
                        alignment: space-between;
                        GeneralCard {
                            switch: MainState.is_light_theme();
                            icon-on: @image-url("../assets/sleek/filled/bulb.svg");
                            icon-off: @image-url("../assets/sleek/outlined/bulb.svg");
                            on-open => {
                                root.set_dark_theme();
                            }
                            on-close => {
                                root.set_light_theme();
                            }
                        }

                        GeneralCard {
                            switch: false;
                            icon-on: @image-url("../assets/sleek/outlined/fullscreen.svg");
                            icon-off: @image-url("../assets/sleek/outlined/fullscreen-exit.svg");
                        }

                        GeneralCard {
                            switch: true;
                            icon-on: @image-url("../assets/sleek/outlined/zhihu.svg");
                            icon-off: @image-url("../assets/sleek/filled/zhihu-square.svg");
                        }

                        GeneralCard {
                            switch: true;
                            icon-on: @image-url("../assets/sleek/filled/wifi-signal-3.svg");
                            icon-off: @image-url("../assets/sleek/filled/wifi-slash.svg");
                        }

                        GeneralCard {
                            switch: false;
                            icon-on: @image-url("../assets/sleek/filled/bluetooth-on.svg");
                            icon-off: @image-url("../assets/sleek/filled/bluetooth-off.svg");
                        }
                    }
                }

                Mpris { }

                UCard {
                    width: parent.width - 2 * UAppTheme.spacing-medium;
                    VerticalLayout {
                        padding: UAppTheme.padding-big;
                        spacing: UAppTheme.spacing-big;
                        padding-left: UAppTheme.padding-big;
                        HorizontalLayout {
                            spacing: UAppTheme.spacing-bigger;
                            width: parent.width - 2 * UAppTheme.spacing-big;
                            height: 20px;
                            UIcon {
                                width: 25px;
                                image-fit: cover;
                                source: @image-url("../assets/sleek/filled/sound.svg");
                            }

                            vol-slider := USlider {
                                min-value: 0;
                                max-value: 120;
                                width: parent.width - 25px - 2 * UAppTheme.spacing-medium;
                                released(val) => {
                                    MainState.set-volume(val);
                                }
                            }
                        }

                        HorizontalLayout {
                            spacing: UAppTheme.spacing-bigger;
                            width: parent.width - 2 * UAppTheme.spacing-big;
                            height: 20px;
                            UIcon {
                                width: 25px;
                                image-fit: cover;
                                source: @image-url("../assets/sleek/filled/sun.svg");
                            }

                            bright-slider := USlider {
                                min-value: 0;
                                max-value: 100;
                                width: parent.width - 25px - 2 * UAppTheme.spacing-medium;
                                released(val) => {
                                    MainState.set-bright(val);
                                }
                            }
                        }

                        HorizontalLayout {
                            spacing: UAppTheme.spacing-bigger;
                            width: parent.width - 2 * UAppTheme.spacing-big;
                            height: 20px;
                            UIcon {
                                width: 25px;
                                image-fit: cover;
                                source: @image-url("../assets/sleek/outlined/mic-on.svg");
                            }

                            mic-slider := USlider {
                                min-value: 0;
                                max-value: 120;
                                width: parent.width - 25px - 2 * UAppTheme.spacing-medium;
                                released(val) => {
                                    MainState.set-mic(val);
                                }
                            }
                        }
                    }
                }

                UCard {
                    width: parent.width - 2 * UAppTheme.padding-medium;
                    VerticalLayout {
                        padding: UAppTheme.padding-medium;
                        alignment: space-between;
                        HorizontalLayout {
                            spacing: UAppTheme.spacing-medium;
                            UIcon {
                                vertical-alignment: ImageVerticalAlignment.top;
                                source: @image-url("../assets/sleek/filled/cpu.svg");
                            }

                            Rectangle {
                                width: parent.width - 2 * UAppTheme.padding-big;
                                cpu-bar := ULinearProgress {
                                    width: parent.width;
                                    progress: MainState.cpu;
                                }
                            }
                        }

                        HorizontalLayout {
                            spacing: UAppTheme.spacing-medium;
                            UIcon {
                                vertical-alignment: ImageVerticalAlignment.top;
                                source: @image-url("../assets/sleek/filled/disk.svg");
                            }

                            Rectangle {
                                width: parent.width - 2 * UAppTheme.padding-big;
                                disk-bar := ULinearProgress {
                                    width: parent.width;
                                    progress: 50%;
                                }
                            }
                        }
                    }
                }
            }
        }

        power-menu := Rectangle {
            x: 0px;
            background: UAppTheme.bg-spotlight;
            width: 50px;
            Rectangle {
                clip: true;
                y: UAppTheme.padding-medium;
                border-radius: UAppTheme.radius-medium;
                height: 50px;
                width: parent.width - 2 * UAppTheme.padding-medium;
                Image {
                    height: 50px;
                    source: @image-url("../assets/logo_dark.png");
                }
            }

            VerticalLayout {
                padding: UAppTheme.padding-medium;
                spacing: UAppTheme.spacing-medium;
                y: parent.height - (4 * self.width - 3 * UAppTheme.padding-medium);
                height: 4 * self.width - 3 * UAppTheme.padding-medium;
                UIconButton {
                    width: parent.width - (2 * UAppTheme.padding-medium);
                    height: self.width;
                    // (parent.height / 10) - (UAppTheme.padding-medium);
                    variant: primary;
                    icon: @image-url("../assets/sleek/outlined/poweroff.svg");
                    clicked => {
                        root.power-action("poweroff");
                    }
                }

                UIconButton {
                    width: parent.width - (2 * UAppTheme.padding-medium);
                    height: self.width;
                    // (parent.height / 10) - (UAppTheme.padding-medium);
                    variant: primary;
                    icon: @image-url("../assets/sleek/outlined/moon.svg");
                    clicked => {
                        root.power-action("sleep");
                    }
                }

                UIconButton {
                    width: parent.width - (2 * UAppTheme.padding-medium);
                    height: self.width;
                    // (parent.height / 10) - (UAppTheme.padding-medium);
                    variant: primary;
                    icon: @image-url("../assets/sleek/outlined/logout.svg");
                    clicked => {
                        root.power-action("logout");
                    }
                }

                UIconButton {
                    width: parent.width - (2 * UAppTheme.padding-medium);
                    height: self.width;
                    // (parent.height / 10) - (UAppTheme.padding-medium);
                    variant: primary;
                    icon: @image-url("../assets/sleek/outlined/lock.svg");
                    clicked => {
                        root.power-action("lock");
                    }
                }
            }
        }
    }
}

export component TopBar inherits Window {
    callback search-toggle(bool);
    callback query-applications(string);
    callback query-clipboard(string);
    callback open-app(string);
    callback set-clip(string);
    property <bool> search-active: false;
    property <SelectedSection> selected: Application;
    pure function selected-string(selection: SelectedSection) -> string {
        if selection == SelectedSection.Application {
            return "Applications";
        } else if selection == SelectedSection.Clipboard {
            return "Clipboard";
        } else if selection == SelectedSection.Wifi {
            return "Wifi";
        } else if selection == SelectedSection.Bluetooth {
            return "Bluetooth";
        } else if selection == SelectedSection.WallPaper {
            return "Wallpapers";
        } else if selection == SelectedSection.Emoji {
            return "Emojis";
        } else {
            return "";
        }
    }
    function tab-selection(selection: SelectedSection) {
        if selection == SelectedSection.Application {
            root.selected = SelectedSection.Clipboard;
        } else if selection == SelectedSection.Clipboard {
            root.selected = SelectedSection.Wifi;
        } else if selection == SelectedSection.Wifi {
            root.selected = SelectedSection.Bluetooth;
        } else if selection == SelectedSection.Bluetooth {
            root.selected = SelectedSection.WallPaper;
        } else if selection == SelectedSection.WallPaper {
            root.selected = SelectedSection.Emoji;
        } else if selection == SelectedSection.Emoji {
            root.selected = SelectedSection.Application
        }
    }
    function shift-tab-selection(selection: SelectedSection) {
        if selection == SelectedSection.Application {
            root.selected = SelectedSection.Emoji;
        } else if selection == SelectedSection.Clipboard {
            root.selected = SelectedSection.Application;
        } else if selection == SelectedSection.Wifi {
            root.selected = SelectedSection.Clipboard;
        } else if selection == SelectedSection.Bluetooth {
            root.selected = SelectedSection.Wifi;
        } else if selection == SelectedSection.WallPaper {
            root.selected = SelectedSection.Bluetooth;
        } else if selection == SelectedSection.Emoji {
            root.selected = SelectedSection.WallPaper;
        }
    }
    changed search-active => {
        // Changes the input region in wayland add backs the keyboard compatibility
        search-toggle(search-active);
        if root.search-active {
            search-bar.grab-focus();
        } else {
            search-bar.remove-focus();
            root.selected = SelectedSection.Application;
        }
    }
    background: transparent;
    width: 1536px;
    height: 610px;
    in-out property <bool> wifi-on: true;
    in-out property <[AppLineData]> app_lines:[
        {
            image: @image-url("../assets/logo_dark.png"),
            name: "Some Name1",
            action :"Some Action"
        },
        {
            image: @image-url("../assets/logo_dark.png"),
            name: "Some Name2",
            action :"Some Action"
        },
    ];
    in-out property <[string]> clip_lines: ["clip1", "clip2"];
    in-out property <[WifiLineData]> wifi_lines: [
        {
            name: "Net 1",
            strength: 90%,
            connection-status: ConnectionStatus.Connected,
        },
        {
            name: "Net 2",
            strength: 50%,
            connection-status: ConnectionStatus.Known,
        },
        {
            name: "Net 3, sdkjsakdslkdaldas",
            strength: 60%,
            connection-status: ConnectionStatus.Unknown,
        },
        {
            name: "Net 4",
            strength: 90%,
            connection-status: ConnectionStatus.Unknown,
        },
        {
            name: "Net 4",
            strength: 90%,
            connection-status: ConnectionStatus.Unknown,
        },
        {
            name: "Net 4",
            strength: 90%,
            connection-status: ConnectionStatus.Unknown,
        },
    ];
    in-out property <bool> is-inhibit: false;
    in-out property <int> connected-network: 1;
    in-out property <bool> run-once: true;

    Timer {
        running: run-once;
        interval: 1s;
        triggered => {
        // Update bar state with actual conditions.
        // Cases:
        // 1. Is headphone connected(callback later if it fails).
        // 2. State of inhibitor.
        // 3. State of Wifi and Bluetooth initially.
            run-once = false;
            // stop-inhibtor();
        }
    }

    Timer {
        running: true;
        interval: 1s;
        triggered => {
            MainState.get-time();
            MainState.get-mic();
            MainState.get-volume();
            MainState.get-cpu();
        }
    }

    selection-section := Rectangle {
        width: 435px;
        height: 450px;
        background: transparent;
        y: search-active ? 35px : -600px;

        Path {
            x: 0px;
            y: 0px;
            commands: "M 7 3 L 12 3 L 12 8 C 11 5 10 4 7 3";
            stroke: UAppTheme.bg-container;
            fill: UAppTheme.bg-container;
            width: 10px;
            height: 10px;
        }

        option-window := OptionSection {
            width: parent.width - 20px;
            selection: root.selected;
            app_lines: root.app_lines;
            clip_lines: root.clip_lines;
            wifi_lines: root.wifi_lines;
            wifi-on: wifi-on;
            connected-network: connected-network;
            set-app(val) => {
                open-app(app_lines[val].name);
            }
            set-clip(val) => {
                set-clip(clip_lines[val]);
            }
            escape-focus => {
                search-bar.grab-focus();
            }
        }

        Path {
            x: parent.width - 10px;
            y: 0px;
            commands: "M 7 8 L 7 3 L 12 3 C 9 4 8 5 7 8";
            stroke: UAppTheme.bg-container;
            fill: UAppTheme.bg-container;
            width: 10px;
            height: 10px;
        }

        animate y { duration: UAppTheme.animation-duration; }
    }

    bar-section := Rectangle {
        height: 35px;
        y: 0px;
        clip: true;
        background: UAppTheme.bg-container;
        HorizontalLayout {
            spacing: UAppTheme.spacing-small;
            padding: UAppTheme.padding-base;
            Rectangle {
                width: 28px;
                UIcon {
                    source: @image-url("../assets/icons/artixlinux.svg");
                    image-fit: ImageFit.contain;
                }

                icon-handle := TouchArea {
                    mouse-cursor: MouseCursor.pointer;
                    clicked => {
                        search-active = !search-active;
                    }
                }
            }

            Rectangle {
                search-section := Rectangle {
                    y: search-active ? 0px : -35px;
                    background: UAppTheme.bg-container;
                    HorizontalLayout {
                        spacing: UAppTheme.spacing-medium;
                        alignment: LayoutAlignment.center;
                        UButton {
                            text: "Application";
                            variant: selected == SelectedSection.Application ? primary : default;
                            clicked => {
                                selected = SelectedSection.Application;
                            }
                        }

                        UButton {
                            text: "Clipboard";
                            variant: selected == SelectedSection.Clipboard ? primary : default;
                            clicked => {
                                selected = SelectedSection.Clipboard;
                            }
                        }

                        UButton {
                            text: "Wifi";
                            variant: selected == SelectedSection.Wifi ? primary : default;
                            clicked => {
                                selected = SelectedSection.Wifi;
                            }
                        }

                        search-bar := UInput {
                            width: 300px;
                            placeholder: "Search " + selected_string(selected) + "...";
                            accepted => {
                                if selected == SelectedSection.Application {
                                    open-app(app_lines[option-window.selected-content].name);
                                } else if selected == SelectedSection.Clipboard {
                                    set-clip(clip_lines[option-window.selected-content])
                                }
                            }
                            edited => {
                                if selected == SelectedSection.Application {
                                    query-applications(self.text);
                                } else if selected == SelectedSection.Clipboard {
                                    query-clipboard(self.text);
                                }
                            }
                            key-pressed(event) => {
                                if event.text == Key.Tab {
                                    tab-selection(root.selected);
                                    accept;
                                } else if event.text == Key.Backtab {
                                    shift-tab-selection(root.selected);
                                    accept;
                                } else if event.text == Key.DownArrow {
                                    if option-window.selected-content < app_lines.length - 1 {
                                        option-window.selected-content += 1;
                                    }
                                    accept;
                                } else if event.text == Key.UpArrow {
                                    if option-window.selected-content > 0 {
                                        option-window.selected-content -= 1;
                                    }
                                    accept;
                                } else if event.text == Key.Escape {
                                    if root.search-active {
                                        search-active = false;
                                    } else {
                                        search-active = true;
                                    }
                                    accept;
                                } else {
                                    debug(event.modifiers.shift);
                                    debug(event.text);
                                    reject;
                                }
                            }
                        }

                        UButton {
                            text: "Bluetooth";
                            variant: selected == SelectedSection.Bluetooth ? primary : default;
                            clicked => {
                                selected = SelectedSection.Bluetooth;
                            }
                        }

                        UButton {
                            text: "Wallpapers";
                            variant: selected == SelectedSection.WallPaper ? primary : default;
                            clicked => {
                                selected = SelectedSection.WallPaper;
                            }
                        }

                        UButton {
                            text: "Emojis";
                            variant: selected == SelectedSection.Emoji ? primary : default;
                            clicked => {
                                selected = SelectedSection.Emoji;
                            }
                        }
                    }

                    animate y { duration: UAppTheme.animation-duration; }
                }

                display-section := DisplayComponent {
                    time: MainState.time;
                    vol: MainState.vol;
                    mic: MainState.mic;
                    cpu: MainState.cpu;
                    is-inhibit: is-inhibit;
                    get-search-active => {
                        search-active
                    }
                    toggle-search-active => {
                        search-active = !search-active;
                    }
                    select-wifi => {
                        selected = SelectedSection.Wifi;
                    }
                    select-bluetooth => {
                        selected = SelectedSection.Bluetooth;
                    }
                }
            }
        }
    }

    Rectangle {
        y: 35px;
        height: 10px;
        Path {
            y: 0px;
            x: 0px;
            commands: "M 7 8 L 7 3 L 12 3 C 9 4 8 5 7 8";
            stroke: UAppTheme.bg-container;
            fill: UAppTheme.bg-container;
            width: 10px;
        }

        Path {
            x: 1525px;
            commands: "M 7 3 L 12 3 L 12 8 C 11 5 10 4 7 3";
            stroke: UAppTheme.bg-container;
            fill: UAppTheme.bg-container;
            width: 10px;
        }
    }
}

export component HideWin inherits Window {
    callback request-hide();
    Text {
        horizontal-alignment: TextHorizontalAlignment.center;
        vertical-alignment: TextVerticalAlignment.center;
        text: "Hello";
    }

    TouchArea {
        clicked => {
            root.request-hide();
        }
    }
}

export component AppWindow inherits Window {
    in-out property <int> counter: 42;
    callback request-increase-value();
    width: 376px;
    height: 576px;
    VerticalBox {
        Text {
            text: "Counter: \{root.counter}";
        }

        Button {
            text: "Increase value";
            clicked => {
                root.request-increase-value();
            }
        }
    }
}

export component LockScreen inherits Window {
    in-out property <bool> is_lock_activated: false;
    in-out property <bool> lock_error: false;
    callback check-pass(string);
    callback request_time();
    callback verify_fingerprint();
    in-out property <string> time_var: "04:34";
    in-out property <string> time_ampm: "AP";
    in-out property <string> finger_verification_response;
    in-out property <bool> finger_again: true;
    in-out property <int> no_of_attempts: 0;

    Timer {
        interval: 2s;
        running: finger_again;
        triggered => {
            finger_again = false;
            verify_fingerprint();
        }
    }

    Timer {
        interval: 1s;
        running: true;
        triggered => {
            if no_of_attempts < 3 && !finger_again {
                no_of_attempts += 1;
                finger_again = true;
            } else {
                self.stop();
            }
        }
    }

    Timer {
        interval: 200ms;
        running: true;
        triggered => {
            request_time();
        }
    }

    Timer {
        interval: 2s;
        running: lock_error;
        triggered => {
            lock_error = false;
        }
    }

    Rectangle {
        width: parent.width;
        Image {
            width: parent.width;
            source: @image-url("../../../../assets/wallpapers/city lights/wallpaperflare.com_wallpaper(5).jpg");
            image-fit: cover;
        }

        TouchArea {
            clicked => {
                if is_lock_activated {
                    is_lock_activated = false;
                } else {
                    is_lock_activated = true;
                }
            }
        }
    }

    Rectangle {
        height: parent.height;
        x: is_lock_activated ? root.width - 350px : root.width;
    // x: root.width - 350px;
    // opacity: is_lock_activated ? 100 : 0;
    width: 350px;
        Image {
            height: parent.height;
            source: @image-url("../assets/frosted_glass_2.jpeg");
        }

        Rectangle {

            Text {
                x: 50px;
                y: 220px;
                vertical-alignment: TextVerticalAlignment.center;
                horizontal-alignment: TextHorizontalAlignment.center;
                color: Styles.font-color-light;
                font-size: 75px;
                font-family: "Source Code Pro";
            // font-family: "DS DIGI Orbitron-Regular";
            text: time_var;
            }

            Text {
                x: 275px;
                y: 258px;
                vertical-alignment: TextVerticalAlignment.center;
                horizontal-alignment: TextHorizontalAlignment.center;
                color: Styles.font-color-light;
                font-size: 35px;
                font-family: "Source Code Pro";
                text: time_ampm;
            }

            Text {
                y: 310px;
                vertical-alignment: TextVerticalAlignment.center;
                horizontal-alignment: TextHorizontalAlignment.center;
                color: Styles.font-color-light;
                font-size: 35px;
                font-family: "Source Code Pro";
                text: "Welcome Back!";
            }

            input := LineEdit {
                input-type: password;
                height: 37px;
                width: 260px;
                font-size: 20px;
                placeholder-text: " Enter Password";
                accepted(text) => {
                    root.check-pass(text);
                    self.text = "";
                }
                init => {
                    self.focus();
                }
            }

            Text {
                y: 410px;
                font-size: 25px;
                font-family: "Source Code Pro";
                text: "Incorrect Password";
                opacity: lock_error ? 100 : 0;
            }

            Text {
                y: 410px;
                font-size: 25px;
                font-family: "Source Code Pro";
                text: finger_verification_response;
                opacity: !finger_again ? 100 : 0;
            }

            Text {
                y: parent.height - 50px;
                font-size: 20px;
                color: pink;
                font-weight: 60;
                font-family: "Orbitron Variable";
                text: "Entering Terra Incognita Space !!";
            }
        }

        animate x {
            delay: 200ms;
            duration: 500ms;
            easing: ease-in-out-quad;
        }
    }
}

export component Workspaces inherits Window {
    in-out property <[bool]> is-filled: [false, false, false, false, false, false, false, false, false, false];
    in-out property <[bool]> is-active: [false, false, false, false, false, false, false, false, false, false];
    callback refresh-workspaces();
    callback refresh-vol();
    callback refresh-info();
    callback change_called(int);
    width: 7px;
    x: 0px;
    height: 830px;
    background: Styles.dark-background;

    Timer {
        interval: 300ms;
        triggered => {
            refresh-workspaces();
            refresh-vol();
        }
    }

    Timer {
        interval: 3s;
        triggered => {
            refresh-info();
        }
    }

    VerticalLayout {
        y: 0px;
        alignment: LayoutAlignment.space-evenly;
        height: parent.height;
        spacing: 4px;
        for i in 10: WorkspaceButton {
            sugg_int: (parent.height / 10) - 4px;
            is_filled: is-filled[i];
            is-active: is-active[i];
            change_called => {
                change_called(i)
            }
        }
    }
}
