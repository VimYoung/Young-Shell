import { Styles } from "styles.slint";
import { Button, LineEdit } from "std-widgets.slint";
export component PowerMenuButton inherits Rectangle {
    in property <image> icon;
    in property <image> icon-open;
    in property <string> label;
    in property <bool> is-open: false;
    in property <length> button-width: 30px;
    in property <bool> is-special: false;
    callback clicked();

    width: button-width;
    height: 40px;
    background: Styles.light-blue;
    border-radius: 10px;
    clip: true;

    // HorizontalLayout {
    //     padding: Styles.padding - 3px;
    //     width: root.width;
    //     alignment: LayoutAlignment.start;
    //     spacing: Styles.padding;

    label-text := Text {
        text: label;
        color: Styles.font-color-dark;
        font-family: "Urbanist-Bold";
        font-weight: 500;
        font-size: 23px;
        x: is-open ? 34px : -180px;
        vertical-alignment: TextVerticalAlignment.center;

        animate x { duration: 200ms; }
        // }
    }

    Rectangle {
        background: Styles.light-blue;
        x: 0px;
        width: is-special ? root.width : 30px;
        Image {
            x: is-special ? (is-open ? 75px : 5px) : 5px;
            width: 20px;
            source: is-special ? (is-open ? icon-open : icon) : icon;
            colorize: Styles.font-color-dark;
            animate x { duration: 200ms; }
        }
    }

    TouchArea {
        clicked => {
            root.clicked();
        }
    }
}

export component MenuButton {
    in property <image> icon;
    callback clicked();
    // width: menu.width - (root.width );
    width: 50px;
    height: 50px;
    Rectangle {
        border-radius: 20px;
        background: #AEEEEE;
        Image {
            width: root.width - 28px;
            source: icon;
        }

        TouchArea {
            clicked => {
                root.clicked();
            }
        }
    }
}

export component GeneralButton inherits Rectangle {
    in property <image> icon: @image-url("../assets/icons/chevron-right.svg");
    in property <length> button-width: 35px;
    in property <length> button-rad: 15px;
    background: #015B96;
    border-radius: button-rad;
    width: button-width;
    min-height: 30px;
    Image {
        width: 20px;
        source: icon;
        colorize: white;
    }

    TouchArea {
        clicked => {
        }
    }
}

export component AppDisplayButton inherits Rectangle {
    callback open_app();
    in property <image> image_path: @image-url("/home/ramayen/assets/app_images/.icons/logseq.png");
    in property <string> app_name: "Discord";
    in property <bool> is_app_selected: false;
    height: 50px;
    border-width: 1px;
    border-radius: 10px;
    background: sensor.has-hover ? Styles.base-background : Styles.dark-background;
    border-color: Styles.border-color;
    HorizontalLayout {
        spacing: 20px;
        alignment: LayoutAlignment.start;
        padding: 9px;
        Image {
            y: 5px;
            height: 35px;
            width: 35px;
            source: image_path;
        }

        Text {
            vertical-alignment: TextVerticalAlignment.center;
            color: Styles.font-color-light;
            text: app_name;
            font-size: 25px;
        }
    }

    animate background { duration: 100ms; }
    sensor := TouchArea {
        clicked => {
            root.open_app()
        }
    }
}

export component WifiButton inherits Rectangle {
    in-out property <string> name;
    in-out property <int> strength;
    in-out property <bool> width-expanded: false;
    in-out property <bool> connect-win-open: true;
    callback connect();
    x: 0px;
    border-radius: 10px;
    height: width-expanded ? 100px : 50px;
    background: sensor.has-hover ? Styles.base-background : Styles.dark-background;
    border-color: Styles.border-color;
    border-width: 1px;
    clip: true;
    animate height, background { duration: 200ms; }
    sensor := TouchArea {
        clicked => {
            if width-expanded {
                width-expanded = false;
            } else {
                width-expanded = true;
                connect-win-open = false;
            }
        }
    }

    Rectangle {
        height: 50px;
        y: 0px;
        Text {
            x: 10px;
            vertical-alignment: TextVerticalAlignment.center;
            color: Styles.font-color-light;
            text: strength;
            font-size: 20px;
        }

        Path {
            x: 30px;
            width: 10px;
            commands: "M 66 23 C 67 22 66 22 67 23 L 67 48 C 67 49 66 49 66 48 C 66 30 66 30 66 23";
            height: parent.height - 15px;
            fill: white;
        }

        Text {
            x: 45px;
            color: Styles.font-color-light;
            text: name;
            font-size: 25px;
        }

        Rectangle {
            width: 75px;
            height: parent.height - 20px;
            border-color: inner.has-hover ? Styles.light-blue : Styles.light-blue-b;
            border-width: inner.has-hover ? 1px : 2px;
            border-radius: 10px;
            x: root.width - 90px;
            Text {
                text: "Connect";
                font-size: 15px;
                font-weight: inner.has-hover ? 500 : 800;
                color: inner.has-hover ? Styles.light-blue : Styles.light-blue-a;
            }

            inner := TouchArea {
                clicked => {
                    if width-expanded {
                        width-expanded = false;
                        connect-win-open = false;
                    } else {
                        width-expanded = true;
                        connect-win-open = true;
                    }
                    root.connect();
                }
            }
        }

        Rectangle {
            width: 75px;
            height: parent.height - 20px;
            border-width: 1px;
            border-radius: 10px;
            x: root.width - 175px;
            border-color: inner_sec.has-hover ? Styles.light-blue : Styles.pink-border;
            background: inner_sec.has-hover ? Styles.hover-background : Styles.dark-background;
            Text {
                text: "Delete";
                font-size: 15px;
                font-weight: 500;
                color: inner_sec.has-hover ? Styles.light-blue : Styles.pink-border;
            }

            inner_sec := TouchArea {
                clicked => {
                }
            }
        }
    }

    Rectangle {
        y: 50px;
        height: 50px;
        width: root.width - 20px;
        Text {
            text: "Network Information will come here";
            font-size: 15px;
        }
    }

    Rectangle {
        y: connect-win-open ? 50px : 100px;
        height: 50px;
        width: root.width - 20px;
        LineEdit {
            width: parent.width;
            input-type: password;
            placeholder-text: "Enter Password";
        }
    }
}

export component WifiButtonConnected inherits Rectangle {
    in-out property <string> name;
    in-out property <int> strength;
    in-out property <bool> width-expanded: false;
    in-out property <bool> connect-win-open: true;
    callback disconnect();
    x: 0px;
    border-radius: 10px;
    height: width-expanded ? 100px : 50px;
    background: sensor.has-hover ? Styles.base-background : Styles.dark-background;
    border-color: Styles.border-color;
    border-width: 1px;
    clip: true;
    animate height, background { duration: 200ms; }
    sensor := TouchArea {
        clicked => {
            if width-expanded {
                width-expanded = false;
            } else {
                width-expanded = true;
                connect-win-open = false;
            }
        }
    }

    Rectangle {
        height: 50px;
        y: 0px;

        Text {
            x: 10px;
            color: Styles.font-color-light;
            text: name;
            font-size: 25px;
        }

        Rectangle {
            width: 85px;
            height: parent.height - 20px;
            border-width: 2px;
            border-radius: 10px;
            x: root.width - 100px;
            border-color: inner.has-hover ? Styles.light-blue : Styles.pink-border;
            background: inner.has-hover ? Styles.hover-background : Styles.dark-background;
            Text {
                text: "Disconnect";
                font-size: 15px;
                color: inner.has-hover ? Styles.light-blue : pink;
            }

            inner := TouchArea {
                clicked => {
                    root.disconnect();
                }
            }
        }
    }

    Rectangle {
        y: 50px;
        height: 50px;
        width: root.width - 20px;
        Text {
            text: "Network Information will come here";
            font-size: 15px;
        }
    }
}

